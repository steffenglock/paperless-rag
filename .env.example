# ── Paperless-ngx ──────────────────────────────────────────
PAPERLESS_URL=http://paperless-ngx:8000
PAPERLESS_TOKEN=your_api_token_here

# ── LLM Provider ───────────────────────────────────────────
# "ollama" | "openai" | "openrouter"
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=
LLM_MODEL=llama3.2

# ── Embedding Provider ──────────────────────────────────────
# "ollama" | "openai" | "openrouter"
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text

# ── Security ────────────────────────────────────────────────
# 32-Byte Hex-String: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change_me_generate_a_real_key_here

# ── App ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
